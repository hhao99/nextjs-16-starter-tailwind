    "@types/react-dom": "19.2.3",
    "baseline-browser-mapping": "2.10.37",
    "eslint": "10.5.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-tailwindcss": "3.18.3",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
